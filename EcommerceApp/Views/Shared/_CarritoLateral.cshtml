@model List<EcommerceApp.Models.CarritoItem>

@{
    int subtotalSuma = Model.Sum(x => x.Subtotal);
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-cart-shopping fs-1 mb-3 opacity-50"></i>
        <p class="mb-0">Tu bolsa está vacía</p>
    </div>
}
else
{
    <div class="list-group list-group-flush mb-4 text-start">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent text-white px-0 py-3 border-bottom border-secondary d-flex align-items-center">
                <img src="@item.Producto.ImagenUrl" class="rounded-2 object-fit-cover me-3" style="width: 50px; height: 50px;">

                <div class="flex-grow-1">
                    <h6 class="fw-bold mb-1 text-light" style="font-size: 0.9rem;">@item.Producto.Nombre</h6>
                    <div class="d-flex align-items-center">
                        <span class="text-primary fw-bold small">$ @item.Producto.Precio.ToString("N0")</span>
                        <span class="badge bg-secondary text-light ms-2">x@(item.Cantidad)</span>
                    </div>
                </div>

                <div class="ms-3 text-end">
                    <span class="fw-black text-white small">$ @item.Subtotal.ToString("N0")</span>
                </div>
            </div>
        }
    </div>

    <div class="mt-auto pt-3 border-top border-secondary">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small fw-bold">SUBTOTAL:</span>
            <h5 class="text-success fw-black mb-0">$ @subtotalSuma.ToString("N0") CLP</h5>
        </div>

        <a asp-controller="Home" asp-action="VerCarrito" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
            Ir a Finalizar Compra <i class="fa-solid fa-arrow-right ms-1"></i>
        </a>
    </div>
}