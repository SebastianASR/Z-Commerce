@model List<EcommerceApp.Models.CarritoItem>

@{
    int subtotalSuma = Model.Sum(x => x.Subtotal);
    int totalItems = Model.Sum(x => x.Cantidad);
}

@Html.AntiForgeryToken()

<input type="hidden" id="cartTotalItems" value="@totalItems" />

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-cart-shopping fs-1 mb-3 opacity-50"></i>
        <p class="mb-1 fw-bold">Tu bolsa está vacía</p>
        <p class="small mb-0 opacity-75">Agrega productos del catálogo para comenzar tu compra.</p>
    </div>
}
else
{
    <div class="list-group list-group-flush mb-4 text-start">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent text-white px-0 py-3 border-bottom border-secondary">
                <div class="d-flex align-items-center">
                    <img src="@item.Producto.ImagenUrl"
                         class="rounded-2 object-fit-cover me-3 border border-secondary border-opacity-25"
                         style="width: 58px; height: 58px;"
                         alt="@item.Producto.Nombre" />

                    <div class="flex-grow-1">
                        <h6 class="fw-bold mb-1 text-light" style="font-size: 0.9rem;">
                            @item.Producto.Nombre
                        </h6>

                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <span class="text-primary fw-bold small">
                                $ @item.Producto.Precio.ToString("N0")
                            </span>

                            <span class="badge bg-secondary text-light">
                                x@(item.Cantidad)
                            </span>
                        </div>
                    </div>

                    <div class="ms-3 text-end">
                        <span class="fw-black text-white small">
                            $ @item.Subtotal.ToString("N0")
                        </span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 ps-0 ps-sm-5 flex-wrap">
                    <button type="button"
                            class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold"
                            onclick="actualizarCarrito('/Home/AgregarUnidadCarrito', @item.Producto.Id)">
                        <i class="fa-solid fa-plus me-1"></i> Agregar 1
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-warning rounded-pill px-3 fw-bold"
                            onclick="actualizarCarrito('/Home/QuitarUnidadCarrito', @item.Producto.Id)">
                        <i class="fa-solid fa-minus me-1"></i> Quitar 1
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold"
                            onclick="actualizarCarrito('/Home/EliminarProductoCarrito', @item.Producto.Id)">
                        <i class="fa-solid fa-trash-can me-1"></i> Eliminar
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="mt-auto pt-3 border-top border-secondary">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small fw-bold">SUBTOTAL:</span>
            <h5 class="text-success fw-black mb-0">
                $ @subtotalSuma.ToString("N0") CLP
            </h5>
        </div>

        <button type="button"
                class="btn btn-outline-danger w-100 rounded-3 fw-bold py-2"
                onclick="actualizarCarrito('/Home/VaciarCarrito', null)">
            <i class="fa-solid fa-broom me-2"></i> Vaciar carrito
        </button>
    </div>
}