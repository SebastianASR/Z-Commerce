@using EcommerceApp.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Z-COMMERCE</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            letter-spacing: -0.01em;
        }

        .tracking-wide {
            letter-spacing: 0.05em;
        }

        .epic-logo span {
            display: inline-block;
            font-weight: 900;
            color: #ffffff;
            transform: translateY(0);
            transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1), color 0.3s ease, text-shadow 0.3s ease;
            transition-delay: calc(0.02s * var(--i));
        }

        .epic-logo:hover span {
            transform: translateY(-5px);
            color: var(--clr);
            text-shadow: 0 0 10px var(--clr), 0 4px 15px rgba(13, 110, 253, 0.4);
        }

        .glass-offcanvas {
            background: rgba(24, 24, 27, 0.95) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .nav-link, .btn, .dropdown-item {
            transition: all 0.2s ease-in-out;
        }

            .nav-link:hover {
                color: #0d6efd !important;
                transform: translateY(-1px);
            }

        .btn-login-hover i {
            transition: transform 0.2s ease-in-out, color 0.2s ease-in-out;
        }

        .btn-login-hover:hover i {
            transform: scale(1.15);
            color: #0d6efd !important;
        }

        .btn-register-premium {
            background: rgba(13, 110, 253, 0.15);
            border: 1px solid rgba(13, 110, 253, 0.5);
            color: #ffffff;
            transition: all 0.3s ease;
        }

            .btn-register-premium:hover {
                background: rgba(13, 110, 253, 0.35);
                border-color: #0d6efd;
                box-shadow: 0 0 15px rgba(13, 110, 253, 0.4);
                transform: translateY(-2px);
                color: #ffffff;
            }

        .custom-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scroll::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.1);
        }

        .custom-scroll::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
        }

            .custom-scroll::-webkit-scrollbar-thumb:hover {
                background: rgba(255,255,255,0.3);
            }
    </style>
</head>

<body class="bg-light text-dark d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary border-opacity-25 shadow-sm py-3">
            <div class="container">

                <a class="navbar-brand text-uppercase tracking-wide fs-4 epic-logo d-flex align-items-center text-decoration-none" asp-controller="Home" asp-action="Index">
                    <span style="--i:1; --clr:#0d6efd;"><i class="fa-solid fa-microchip me-1 animate-pulse text-primary"></i>Z</span>
                    <span style="--i:2; --clr:#ffffff;">-</span>
                    <span style="--i:3; --clr:#0d6efd;">C</span>
                    <span style="--i:4; --clr:#3388ff;">O</span>
                    <span style="--i:5; --clr:#ffffff;">M</span>
                    <span style="--i:6; --clr:#ffffff;">M</span>
                    <span style="--i:7; --clr:#3388ff;">E</span>
                    <span style="--i:8; --clr:#0d6efd;">R</span>
                    <span style="--i:9; --clr:#ffffff;">C</span>
                    <span style="--i:10; --clr:#0d6efd;">E</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-lg-4 gap-2 d-flex flex-column flex-lg-row align-items-start align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link text-light fw-medium small text-uppercase tracking-wide text-nowrap" asp-controller="Home" asp-action="Catalogo">
                                <i class="fa-solid fa-layer-group me-1 opacity-75"></i> Catálogo
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light fw-medium small text-uppercase tracking-wide text-nowrap" asp-controller="Home" asp-action="Privacy">
                                <i class="fa-solid fa-shield-halved me-1 opacity-75"></i> Garantía y Seguridad
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center flex-column flex-lg-row gap-3 gap-lg-4 ms-lg-5 w-100 w-lg-auto mt-3 mt-lg-0 justify-content-end">

                        <a href="javascript:void(0)" onclick="abrirCarritoLateral(null)" class="btn btn-outline-primary fw-bold px-4 rounded-3 position-relative d-flex align-items-center justify-content-center w-100 w-lg-auto">
                            <i class="fa-solid fa-cart-shopping me-2"></i> Carrito

                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-dark shadow animate-bounce" id="badgeCartCount" style="display:none; font-size: 0.75rem;">
                                0
                            </span>
                        </a>

                        <div class="vr text-light my-2 d-none d-lg-block opacity-25"></div>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="dropdown w-100 w-lg-auto">
                                <button class="btn btn-dark border border-secondary border-opacity-50 text-light fw-bold dropdown-toggle rounded-3 w-100 text-start text-lg-center" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-user-circle text-primary me-2 fs-5 align-middle"></i>
                                    @User.Identity?.Name

                                    @if (User.IsInRole("DemoAdmin"))
                                    {
                                        <span class="badge bg-warning text-dark ms-2">DEMO</span>
                                    }
                                    else if (User.IsInRole("Admin"))
                                    {
                                        <span class="badge bg-success text-dark ms-2">ADMIN</span>
                                    }
                                </button>

                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg border-secondary border-opacity-50 mt-2 p-2 rounded-3 animate-fadeIn">

                                    @if (User.IsInRole("Admin") || User.IsInRole("DemoAdmin"))
                                    {
                                        <div class="dropdown-header text-uppercase tracking-wider small fw-bold text-primary opacity-75 pb-1">
                                            @(User.IsInRole("DemoAdmin") ? "Modo Demo" : "Gestión Enterprise")
                                        </div>

                                        <li>
                                            <a class="dropdown-item fw-semibold text-warning rounded-2 py-2" asp-controller="Home" asp-action="VerSolicitudes">
                                                <i class="fa-solid fa-envelope-open-text me-2"></i>Leads / Solicitudes
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item fw-semibold text-success rounded-2 py-2" asp-controller="Home" asp-action="GestionProductos">
                                                <i class="fa-solid fa-boxes-stacked me-2"></i>Gestión de Inventario
                                            </a>
                                        </li>

                                        <li><hr class="dropdown-divider border-secondary border-opacity-50 my-2"></li>
                                    }

                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item fw-bold text-danger rounded-2 py-2">
                                                <i class="fa-solid fa-power-off me-2"></i>Cerrar Conexión
                                            </button>
                                        </form>
                                    </li>

                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-link text-light text-decoration-none fw-bold small text-uppercase tracking-wide w-100 w-lg-auto text-center text-nowrap btn-login-hover">
                                <i class="fa-solid fa-lock text-secondary me-2 opacity-75"></i>Ingresar
                            </a>

                            <a asp-controller="Account" asp-action="Register" class="btn btn-register-premium fw-bold px-4 rounded-3 w-100 w-lg-auto text-nowrap">
                                <i class="fa-solid fa-user-plus me-2 opacity-75"></i>Registrarse
                            </a>
                        }
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="container my-5 flex-grow-1">
        <main role="main" class="pb-5 animate-fadeIn">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="container mt-4">
                    <div id="successAlert"
                         class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 d-flex align-items-center"
                         role="alert">
                        <div class="me-3">
                            <i class="fa-solid fa-circle-check fs-4"></i>
                        </div>

                        <div class="flex-grow-1">
                            <strong>Operación exitosa</strong>
                            <div class="small">
                                @TempData["SuccessMessage"]
                            </div>
                        </div>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="alert"
                                aria-label="Cerrar"></button>
                    </div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <div class="offcanvas offcanvas-end glass-offcanvas text-light border-start border-secondary border-opacity-25 shadow-lg"
         tabindex="-1" id="offcanvasCarrito" aria-labelledby="offcanvasCarritoLabel" style="width: 520px; max-width: 95vw;">

        <div class="offcanvas-header border-bottom border-secondary border-opacity-25 px-4 py-3">
            <h5 class="offcanvas-title fw-black tracking-wide text-uppercase text-primary d-flex align-items-center" id="offcanvasCarritoLabel">
                <i class="fa-solid fa-cart-shopping me-2"></i> Tu Carrito
            </h5>

            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column custom-scroll px-4" id="contenedor-carrito-offcanvas">
            <div class="text-center py-5 my-5 text-light opacity-50">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 small tracking-wide text-uppercase">Sincronizando Hardware...</p>
            </div>
        </div>

        <div class="offcanvas-footer p-4 border-top border-secondary border-opacity-25 bg-black bg-opacity-40">
            <a id="btnCheckoutOffcanvas"
               asp-controller="Checkout"
               asp-action="Index"
               class="btn btn-primary btn-lg w-100 fw-bold py-3 rounded-3 shadow-lg text-uppercase tracking-wide">
                Proceder al Checkout <i class="fa-solid fa-cash-register ms-2"></i>
            </a>
        </div>
    </div>

    <footer class="bg-dark text-light text-opacity-50 border-top border-secondary border-opacity-25 py-4 text-start mt-auto">
        <div class="container">
            <div class="row align-items-center g-3">

                <div class="col-md-6 text-center text-md-start">
                    <div class="text-light fw-bold small mb-1 tracking-wide">
                        Z-COMMERCE &copy; 2026 — Arquitectura de Sistemas Distribuidos.
                    </div>

                    <div class="small" style="font-size: 0.8rem;">
                        <i class="fa-solid fa-code text-primary me-2"></i>Full-Stack Developer:
                        <a href="https://github.com/SebastianASR" target="_blank" rel="noopener noreferrer" class="text-white fw-bold text-decoration-none ms-1 hover-underline">
                            Sebastián Sandoval Romero <i class="fa-brands fa-github ms-1 text-primary"></i>
                        </a>
                    </div>
                </div>

                <div class="col-md-6 text-center text-md-end d-flex flex-wrap gap-2 justify-content-center justify-content-md-end">
                    <span class="badge bg-black bg-opacity-50 border border-secondary border-opacity-25 text-light px-2 py-1-5 font-monospace" style="font-size: 0.7rem;">
                        <i class="fa-solid fa-server text-success me-1"></i> NEON_POSTGRESQL
                    </span>

                    <span class="badge bg-black bg-opacity-50 border border-secondary border-opacity-25 text-light px-2 py-1-5 font-monospace" style="font-size: 0.7rem;">
                        <i class="fa-solid fa-credit-card text-info me-1"></i> WEBPAY_API_V1.2
                    </span>

                    <span class="badge bg-primary text-dark fw-bold px-2 py-1-5 font-monospace" style="font-size: 0.7rem;">
                        <i class="fa-solid fa-lock me-1"></i> SSL_SECURE
                    </span>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function actualizarBadgeCarrito() {
            const totalInput = document.getElementById('cartTotalItems');
            const totalItems = totalInput ? (parseInt(totalInput.value) || 0) : 0;

            const badge = document.getElementById('badgeCartCount');

            if (badge) {
                badge.innerText = totalItems;
                badge.style.display = totalItems > 0 ? 'inline-block' : 'none';
            }

            const checkoutBtn = document.getElementById('btnCheckoutOffcanvas');

            if (checkoutBtn) {
                if (totalItems <= 0) {
                    checkoutBtn.classList.add('disabled');
                    checkoutBtn.setAttribute('aria-disabled', 'true');
                    checkoutBtn.setAttribute('tabindex', '-1');
                } else {
                    checkoutBtn.classList.remove('disabled');
                    checkoutBtn.removeAttribute('aria-disabled');
                    checkoutBtn.removeAttribute('tabindex');
                }
            }
        }

        function obtenerTokenCarrito() {
            const tokenInput = document.querySelector('#contenedor-carrito-offcanvas input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        function procesarCarrito(idProducto, abrirFuerza) {
            let url = '/Home/GetCarritoOffcanvas';

            if (idProducto) {
                url += '?idProducto=' + idProducto;
            }

            fetch(url, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(response => {
                    if (!response.ok) throw new Error("Error crítico en la comunicación de red.");
                    return response.text();
                })
                .then(html => {
                    document.getElementById('contenedor-carrito-offcanvas').innerHTML = html;

                    actualizarBadgeCarrito();

                    if (abrirFuerza) {
                        let miOffcanvas = document.getElementById('offcanvasCarrito');
                        let bsOffcanvas = bootstrap.Offcanvas.getInstance(miOffcanvas) || new bootstrap.Offcanvas(miOffcanvas);
                        bsOffcanvas.show();
                    }
                })
                .catch(err => console.error("⚡ [Z-CORE ERROR]: Sincronización de estado fallida:", err));
        }

        function actualizarCarrito(url, idProducto) {
            const token = obtenerTokenCarrito();

            const body = new URLSearchParams();

            if (idProducto !== null && idProducto !== undefined) {
                body.append('id', idProducto);
            }

            if (token) {
                body.append('__RequestVerificationToken', token);
            }

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token,
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: body.toString()
            })
                .then(response => {
                    if (!response.ok) throw new Error("No se pudo actualizar el carrito.");
                    return response.text();
                })
                .then(html => {
                    document.getElementById('contenedor-carrito-offcanvas').innerHTML = html;
                    actualizarBadgeCarrito();

                    let miOffcanvas = document.getElementById('offcanvasCarrito');
                    let bsOffcanvas = bootstrap.Offcanvas.getInstance(miOffcanvas) || new bootstrap.Offcanvas(miOffcanvas);
                    bsOffcanvas.show();
                })
                .catch(err => console.error("⚡ [Z-CORE ERROR]: Operación de carrito fallida:", err));
        }

        function abrirCarritoLateral(idProducto) {
            procesarCarrito(idProducto, true);
        }

        document.addEventListener("DOMContentLoaded", function () {
            procesarCarrito(null, false);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const successAlert = document.getElementById("successAlert");

            if (successAlert) {
                setTimeout(function () {
                    const bootstrapAlert = bootstrap.Alert.getOrCreateInstance(successAlert);
                    bootstrapAlert.close();
                }, 4500);
            }
        });
    </script>
</body>
</html>
