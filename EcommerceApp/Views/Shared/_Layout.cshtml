@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Z-Commerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="bg-light text-dark">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold tracking-wide" asp-controller="Home" asp-action="Index">
                    <span class="text-primary"><i class="fa-solid fa-microchip me-2"></i>Z</span>-COMMERCE
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Catalogo">
                                <i class="fa-solid fa-layer-group me-1"></i> Catálogo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Privacy">
                                <i class="fa-solid fa-shield-halved me-1"></i> Garantía y Seguridad
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        <a href="javascript:void(0)" onclick="abrirCarritoLateral(null)" class="btn btn-outline-primary fw-bold position-relative">
                            <i class="fa-solid fa-cart-shopping me-1"></i> Carrito
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="badgeCartCount" style="display:none;">
                                0
                            </span>
                        </a>

                        <div class="vr text-light my-2 d-none d-lg-block"></div>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="dropdown">
                                <button class="btn btn-link text-light text-decoration-none fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-user-shield text-primary me-1"></i> @User.Identity?.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow border-secondary mt-2">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-bold text-warning" asp-controller="Home" asp-action="VerSolicitudes">
                                                <i class="fa-solid fa-sliders me-2"></i>Panel Admin (Z-SEC)
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider border-secondary"></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item fw-bold text-danger">
                                                <i class="fa-solid fa-power-off me-2"></i>Cerrar Conexión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-link text-light text-decoration-none fw-bold">
                                <i class="fa-solid fa-user me-1"></i> Iniciar Sesión
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary fw-bold">
                                Registrarse
                            </a>
                        }
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="offcanvas offcanvas-end bg-dark text-light border-start border-secondary shadow-lg"
         tabindex="-1" id="offcanvasCarrito" aria-labelledby="offcanvasCarritoLabel" style="width: 580px; max-width: 95vw;">

        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title fw-bold tracking-wide" id="offcanvasCarritoLabel">
                <i class="fa-solid fa-cart-shopping text-primary me-2"></i>TU CARRITO
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column" id="contenedor-carrito-offcanvas">
            <div class="text-center py-5 text-muted">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 small">Cargando tu armamento...</p>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-secondary border-top border-secondary py-4 mt-5 text-start">
        <div class="container">
            <div class="row align-items-center g-3">

                <div class="col-md-6 text-center text-md-start">
                    <div>
                        <span class="fw-bold text-light">Z-COMMERCE</span> &copy; 2026 — Hardware de Alto Rendimiento.
                    </div>
                    <div class="small mt-1 text-white-50">
                        <i class="fa-solid fa-code text-primary me-1"></i> Full-Stack Dev:
                        <a href="https://github.com/SebastianASR" target="_blank" rel="noopener noreferrer" class="text-white fw-bold text-decoration-none">
                            Sebastián Sandoval Romero <i class="fa-brands fa-github ms-1 text-primary"></i>
                        </a>
                    </div>
                </div>

                <div class="col-md-6 text-center text-md-end">
                    <span class="badge bg-secondary text-light me-2"><i class="fa-solid fa-lock me-1"></i> SSL Secure</span>
                    <span class="badge bg-primary"><i class="fa-solid fa-server me-1"></i> Node: CL-STGO-01</span>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function procesarCarrito(idProducto, abrirFuerza) {
            let url = '/Home/GetCarritoOffcanvas';
            if (idProducto) {
                url += '?idProducto=' + idProducto;
            }

            fetch(url)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('contenedor-carrito-offcanvas').innerHTML = html;

                    // Suma matemática corregida a prueba de fallos
                    let filas = document.querySelectorAll('#contenedor-carrito-offcanvas .list-group-item');
                    let totalItems = 0;
                    filas.forEach(f => {
                        let badgeText = f.querySelector('.badge')?.textContent || '1';
                        // Esta línea extrae SOLO los números (ignora la "x" y los espacios)
                        let cant = parseInt(badgeText.replace(/[^0-9]/g, '')) || 1;
                        totalItems += cant;
                    });

                    let badge = document.getElementById('badgeCartCount');
                    badge.innerText = totalItems;
                    badge.style.display = totalItems > 0 ? 'inline-block' : 'none';

                    if (abrirFuerza) {
                        let miOffcanvas = document.getElementById('offcanvasCarrito');
                        let bsOffcanvas = bootstrap.Offcanvas.getInstance(miOffcanvas) || new bootstrap.Offcanvas(miOffcanvas);
                        bsOffcanvas.show();
                    }
                })
                .catch(err => console.error("Error al sincronizar el carrito:", err));
        }

        function abrirCarritoLateral(idProducto) {
            procesarCarrito(idProducto, true);
        }

        document.addEventListener("DOMContentLoaded", function() {
            procesarCarrito(null, false);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>