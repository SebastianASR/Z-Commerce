@model EcommerceApp.Models.Producto
@{
    ViewData["Title"] = "Editar Componente";
}

<div class="container py-5 text-start">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="fw-black mb-4"><i class="fa-solid fa-pen text-primary me-2"></i>Modificar Producto</h2>

            <form asp-action="EditarProducto" method="post" class="card shadow-sm border-0 rounded-4 bg-dark text-white p-4">
                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-md-8">
                        <label asp-for="Nombre" class="form-label small fw-bold text-secondary">NOMBRE DEL PRODUCTO</label>
                        <input asp-for="Nombre" class="form-control bg-transparent text-white border-secondary" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Precio" class="form-label small fw-bold text-secondary">PRECIO (CLP)</label>
                        <input asp-for="Precio" type="number" class="form-control bg-transparent text-white border-secondary" required />
                    </div>
                    <div class="col-12">
                        <label asp-for="ImagenUrl" class="form-label small fw-bold text-warning"><i class="fa-solid fa-link me-1"></i>URL DE LA IMAGEN (POSTIMAGES)</label>
                        <input asp-for="ImagenUrl" class="form-control bg-transparent text-white border-warning" required />
                        <div class="form-text text-muted mt-1"><i class="fa-solid fa-circle-info me-1"></i>Recuerda que el Direct Link debe terminar en .png o .jpg</div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CategoriaId" class="form-label small fw-bold text-secondary">ID CATEGORÍA</label>
                        <input asp-for="CategoriaId" type="number" class="form-control bg-transparent text-white border-secondary" required />
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Descripcion" class="form-label small fw-bold text-secondary">DESCRIPCIÓN COMERCIAL</label>
                        <textarea asp-for="Descripcion" class="form-control bg-transparent text-white border-secondary" rows="3" required></textarea>
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <a asp-action="GestionProductos" class="btn btn-outline-secondary fw-bold me-2">Cancelar</a>
                        <button type="submit" class="btn btn-primary fw-bold px-4">Sobrescribir Datos <i class="fa-solid fa-cloud-arrow-up ms-1"></i></button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>