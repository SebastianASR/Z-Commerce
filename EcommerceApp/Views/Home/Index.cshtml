@model IEnumerable<EcommerceApp.Models.Producto>

@{
    ViewData["Title"] = "Inicio";
}

<div class="position-relative overflow-hidden p-5 mb-5 rounded-4 shadow-lg text-white"
     style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid #334155;">

    <div class="container-fluid py-4 text-start position-relative z-1">
        <span class="badge bg-primary px-3 py-2 text-uppercase tracking-wider mb-3 fw-bold shadow-sm">
            <i class="fa-solid fa-microchip me-1"></i> Stock 2026 Desbloqueado
        </span>

        <h1 class="display-4 fw-extrabold text-white tracking-tight">
            Potencia bruta para tu <span class="text-primary">Setup.</span>
        </h1>

        <p class="col-md-8 fs-5 mt-3 text-light opacity-75">
            Componentes de grado servidor, memorias de ultra-baja latencia y periféricos diseñados para llevar tu hardware al límite.
        </p>

        <div class="d-flex flex-wrap gap-3 mt-4">
            <a asp-action="Catalogo" class="btn btn-primary btn-lg fw-bold px-4 py-3 shadow">
                Abrir Catálogo <i class="fa-solid fa-arrow-right ms-2"></i>
            </a>
            <a asp-action="Privacy" class="btn btn-outline-light btn-lg fw-bold px-4 py-3 opacity-75">
                <i class="fa-solid fa-shield-halved me-2"></i>Nuestra Garantía
            </a>
        </div>
    </div>

    <div class="position-absolute top-0 end-0 translate-middle-y opacity-10 pe-none d-none d-md-block"
         style="font-size: 28rem; color: #38bdf8; right: -5% !important; user-select: none;">
        <i class="fa-solid fa-cpu"></i>
    </div>
</div>

<div class="py-3 px-4 bg-white rounded-4 border shadow-sm mb-5 opacity-75 d-flex justify-content-around align-items-center flex-wrap gap-4 text-muted small fw-bold tracking-widest">
    <span><i class="fa-solid fa-cube me-1 text-success"></i> NVIDIA PARTNER</span>
    <span><i class="fa-solid fa-fire me-1 text-danger"></i> AMD RADEON VIP</span>
    <span><i class="fa-solid fa-atom me-1 text-primary"></i> INTEL PREMIER</span>
    <span><i class="fa-solid fa-shield me-1 text-warning"></i> ASUS ROG ALLIANCE</span>
</div>

<h4 class="fw-bold text-start mb-3">Componentes</h4>
<div class="row row-cols-2 row-cols-md-4 g-3 mb-5 text-start">
    <div class="col">
        <div class="p-3 bg-white rounded-4 border shadow-sm d-flex align-items-center">
            <div class="bg-dark text-primary p-3 rounded-3 me-3 fs-4"><i class="fa-solid fa-microchip"></i></div>
            <div><h6 class="fw-bold text-dark mb-0">Procesadores</h6><small class="text-muted">AMD & Intel</small></div>
        </div>
    </div>
    <div class="col">
        <div class="p-3 bg-white rounded-4 border shadow-sm d-flex align-items-center">
            <div class="bg-dark text-success p-3 rounded-3 me-3 fs-4"><i class="fa-solid fa-vr-cardboard"></i></div>
            <div><h6 class="fw-bold text-dark mb-0">Tarjetas Gráficas</h6><small class="text-muted">RTX & RX</small></div>
        </div>
    </div>
    <div class="col">
        <div class="p-3 bg-white rounded-4 border shadow-sm d-flex align-items-center">
            <div class="bg-dark text-warning p-3 rounded-3 me-3 fs-4"><i class="fa-solid fa-memory"></i></div>
            <div><h6 class="fw-bold text-dark mb-0">Memorias RAM</h6><small class="text-muted">DDR4 & DDR5</small></div>
        </div>
    </div>
    <div class="col">
        <div class="p-3 bg-white rounded-4 border shadow-sm d-flex align-items-center">
            <div class="bg-dark text-danger p-3 rounded-3 me-3 fs-4"><i class="fa-solid fa-hard-drive"></i></div>
            <div><h6 class="fw-bold text-dark mb-0">Almacenamiento</h6><small class="text-muted">NVMe M.2</small></div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-4">
    <div class="text-start">
        <span class="text-primary fw-bold small text-uppercase tracking-wider">Top Ventas</span>
        <h3 class="fw-bold mb-0">Selección Flagship</h3>
    </div>
    <a asp-action="Catalogo" class="btn btn-outline-dark fw-bold small">Ver todo el stock</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5 text-start">
    @foreach (var producto in Model.Take(6))
    {
        int precioNormal = (int)(producto.Precio * 1.15);

        <div class="col">
            <div class="card h-100 shadow-sm border rounded-4 overflow-hidden card-product bg-white">
                <div class="position-relative bg-dark">
                    <span class="position-absolute top-0 end-0 m-3 badge bg-primary fw-bold z-1 shadow-sm">Flagship</span>
                    <img src="@producto.ImagenUrl" class="card-img-top object-fit-cover" alt="@producto.Nombre" style="height: 220px;">
                </div>

                <div class="card-body d-flex flex-column p-4">
                    <small class="text-muted fw-bold small">SKU: ZC-100@(producto.Id)</small>
                    <h5 class="card-title fw-bold mt-1 mb-2 text-dark">@producto.Nombre</h5>
                    <p class="card-text text-muted small flex-grow-1">@producto.Descripcion</p>

                    <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-muted text-decoration-line-through d-block" style="font-size: 0.8rem;">$ @precioNormal.ToString("N0")</small>
                            <h4 class="text-dark fw-black mb-0">$ @producto.Precio.ToString("N0")</h4>
                        </div>
                        <button type="button" onclick="abrirCarritoLateral(@producto.Id)" class="btn btn-primary fw-bold px-3 py-2 shadow-sm btn-agregar">
                            <i class="fa-solid fa-cart-plus me-1"></i> Agregar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="text-center bg-white p-5 rounded-4 border shadow-sm mb-5">
    <h3 class="fw-bold">¿Buscando una placa base, una fuente o pasta térmica?</h3>
    <p class="text-muted mb-4">Nuestra bodega principal cuenta con componentes en tiempo real listos para despacho.</p>
    <a asp-action="Catalogo" class="btn btn-dark btn-lg fw-bold px-5 py-3 shadow">
        <i class="fa-solid fa-boxes-stacked me-2"></i> Abrir Catálogo Completo
    </a>
</div>

<div class="p-5 rounded-4 bg-dark text-light border border-primary border-opacity-50 mb-5 text-start position-relative overflow-hidden shadow-lg">
    <div class="row align-items-center position-relative z-1">
        <div class="col-md-8">
            <span class="badge bg-primary px-3 py-2 text-uppercase mb-3 fw-bold">PROYECTO EMPRESARIAL</span>
            <h2 class="fw-black display-6 text-white">¿Necesitas armar Nodos para Deep Learning o Servidores SQL?</h2>
            <p class="text-secondary mb-0 mt-2 fs-6">Cotiza de forma directa con nuestro equipo de ingenieros. Configuraciones en Rack 2U con fuentes redundantes y arreglos NVMe RAID 10.</p>
        </div>
        <div class="col-md-4 text-md-end mt-4 mt-md-0">
            <a asp-action="AsesoriaVip" class="btn btn-primary btn-lg fw-bold px-4 py-3">
                <i class="fa-solid fa-server me-2"></i> Solicitar Asesoría VIP
            </a>
        </div>
    </div>
</div>

<h4 class="fw-bold text-start mb-4">Lo que dicen nuestros partners</h4>
<div class="row row-cols-1 row-cols-md-3 g-4 mb-5 text-start">

    <div class="col">
        <div class="p-4 bg-white rounded-4 border shadow-sm h-100 d-flex flex-column">
            <div class="text-warning mb-2"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="small text-muted flex-grow-1">"Compré dos Ryzen 9 7950X para armar un clúster de virtualización de bases de datos. El envío llegó a Quinta Normal en menos de 24 horas. Cero dramas con las temperaturas."</p>
            <div class="d-flex align-items-center pt-3 border-top">
                <div class="bg-primary text-white rounded-circle p-2 me-3 fw-bold" style="width:40px; height:40px; text-align:center; line-height: 24px;">PR</div>
                <div><h6 class="fw-bold mb-0 small">Benjamín Vivanco</h6><small class="text-success fw-bold" style="font-size:0.75rem;"><i class="fa-solid fa-circle-check me-1"></i>SysAdmin Verificado</small></div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="p-4 bg-white rounded-4 border shadow-sm h-100 d-flex flex-column">
            <div class="text-warning mb-2"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="small text-muted flex-grow-1">"El soporte me ayudó a verificar si el kit G.Skill de 6000MHz iba a chocar con el perfil EXPO de mi placa MSI. Ensamblé y dio vídeo a la primera. Recomendados."</p>
            <div class="d-flex align-items-center pt-3 border-top">
                <div class="bg-dark text-white rounded-circle p-2 me-3 fw-bold" style="width:40px; height:40px; text-align:center; line-height: 24px;">AG</div>
                <div><h6 class="fw-bold mb-0 small">Camila Aenishanslin</h6><small class="text-success fw-bold" style="font-size:0.75rem;"><i class="fa-solid fa-circle-check me-1"></i>DevOps Lead</small></div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="p-4 bg-white rounded-4 border shadow-sm h-100 d-flex flex-column">
            <div class="text-warning mb-2"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="small text-muted flex-grow-1">"La RTX 4090 venía con su sello de fábrica intacto y la caja impecable. El cifrado de pago me dio mucha confianza para pasar un monto tan alto."</p>
            <div class="d-flex align-items-center pt-3 border-top">
                <div class="bg-success text-white rounded-circle p-2 me-3 fw-bold" style="width:40px; height:40px; text-align:center; line-height: 24px;">LR</div>
                <div><h6 class="fw-bold mb-0 small">Leandro Rojas</h6><small class="text-success fw-bold" style="font-size:0.75rem;"><i class="fa-solid fa-circle-check me-1"></i>Arquitecto Cloud</small></div>
            </div>
        </div>
    </div>

</div>

<style>
    .card-product {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card-product:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12) !important;
        }

    .btn-agregar:active {
        transform: scale(0.95);
    }
</style>