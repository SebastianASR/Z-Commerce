@model IEnumerable<EcommerceApp.Models.Producto>

@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center">
    <!-- Sección Principal (Hero) -->
    <div class="p-5 mb-4 bg-dark text-white rounded-3 shadow">
        <div class="container-fluid py-5">
            <h1 class="display-4 fw-bold">Bienvenido a Z-Commerce</h1>
            <p class="col-md-8 mx-auto fs-5 mt-3">
                Tu tienda de confianza para componentes de hardware, servidores y periféricos de alto rendimiento.
            </p>
            <a href="#" class="btn btn-primary btn-lg mt-3 fw-bold">Explorar Catálogo</a>
        </div>
    </div>

    <!-- Sección de Productos Destacados -->
    <h2 class="mt-5 mb-4 fw-bold text-start">Productos Destacados</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">

        <!-- BUCLE MÁGICO: Aquí C# crea una tarjeta por cada producto en tu "base de datos" -->
        @foreach (var producto in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@producto.ImagenUrl" class="card-img-top rounded-top" alt="@producto.Nombre">
                    <div class="card-body text-start">
                        <h5 class="card-title fw-bold">@producto.Nombre</h5>
                        <p class="card-text text-muted">@producto.Descripcion</p>
                        <!-- Le damos formato al número para que le ponga el punto de los miles (ej: 349.990) -->
                        <h4 class="text-primary fw-bold">$ @producto.Precio.ToString("N0")</h4>
                    </div>
                    <div class="card-footer bg-white border-top-0 pb-3">
                        <a asp-controller="Home" asp-action="AgregarAlCarrito" asp-route-id="@producto.Id" class="btn btn-outline-dark w-100 fw-bold">Agregar al Carrito</a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>