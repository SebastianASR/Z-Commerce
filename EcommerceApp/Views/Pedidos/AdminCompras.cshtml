@model List<EcommerceApp.Models.Pedido>

@{
    ViewData["Title"] = "Compras de Clientes";

    bool esDemoAdmin = ViewBag.EsDemoAdmin == true;

    int totalPedidos = ViewBag.TotalPedidos ?? 0;
    int totalVendido = ViewBag.TotalVendido ?? 0;
    int totalClientes = ViewBag.TotalClientes ?? 0;
    int pedidosPendientes = ViewBag.PedidosPendientes ?? 0;
}

<div class="container py-5 text-start">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-2 fw-bold">
                PANEL ADMINISTRATIVO
            </span>

            <h2 class="fw-black mb-1 mt-2">
                <i class="fa-solid fa-chart-line text-warning me-2"></i>Compras de Clientes
            </h2>

            <p class="text-muted mb-0">
                Visualiza pedidos, clientes, estados de pago y seguimiento de compras registradas.
            </p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Home" asp-action="GestionProductos" class="btn btn-outline-dark fw-bold rounded-3">
                <i class="fa-solid fa-boxes-stacked me-1"></i> Inventario
            </a>

            <a asp-controller="Home" asp-action="VerSolicitudes" class="btn btn-outline-primary fw-bold rounded-3">
                <i class="fa-solid fa-envelope-open-text me-1"></i> Solicitudes
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4">
            <i class="fa-solid fa-circle-check me-2"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (esDemoAdmin)
    {
        <div class="alert alert-warning border-0 rounded-4 shadow-sm mb-4">
            <div class="fw-bold">
                <i class="fa-solid fa-user-shield me-1"></i> Modo DemoAdmin activo
            </div>
            <div class="small">
                Puedes visualizar las compras y revisar detalles, pero no puedes modificar estados ni ejecutar acciones críticas.
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">PEDIDOS</p>
                        <h3 class="fw-black mb-0">@totalPedidos</h3>
                    </div>

                    <div class="bg-primary bg-opacity-10 text-primary rounded-4 p-3">
                        <i class="fa-solid fa-receipt fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">VENTAS AUTORIZADAS</p>
                        <h3 class="fw-black mb-0">$ @totalVendido.ToString("N0")</h3>
                    </div>

                    <div class="bg-success bg-opacity-10 text-success rounded-4 p-3">
                        <i class="fa-solid fa-sack-dollar fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">CLIENTES</p>
                        <h3 class="fw-black mb-0">@totalClientes</h3>
                    </div>

                    <div class="bg-dark bg-opacity-10 text-dark rounded-4 p-3">
                        <i class="fa-solid fa-users fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">EN PROCESO</p>
                        <h3 class="fw-black mb-0">@pedidosPendientes</h3>
                    </div>

                    <div class="bg-warning bg-opacity-10 text-warning rounded-4 p-3">
                        <i class="fa-solid fa-truck-fast fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <div class="mb-3">
                <i class="fa-solid fa-receipt display-4 text-muted opacity-50"></i>
            </div>

            <h4 class="fw-black text-dark mb-2">
                Aún no hay compras registradas
            </h4>

            <p class="text-muted mb-0">
                Cuando los clientes realicen pagos autorizados, sus pedidos aparecerán en este panel.
            </p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Pedido</th>
                            <th class="py-3">Cliente</th>
                            <th class="py-3">Fecha</th>
                            <th class="py-3">Productos</th>
                            <th class="py-3">Pago</th>
                            <th class="py-3">Estado</th>
                            <th class="py-3 text-end">Total</th>
                            <th class="py-3 text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var pedido in Model)
                        {
                            var cantidadProductos = pedido.Detalles.Sum(d => d.Cantidad);

                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">#@pedido.Id</div>

                                    @if (!string.IsNullOrWhiteSpace(pedido.BuyOrder))
                                    {
                                        <small class="text-muted font-monospace">
                                            @pedido.BuyOrder
                                        </small>
                                    }
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">
                                        @pedido.NombreCompleto
                                    </div>

                                    <small class="text-muted d-block">
                                        @pedido.Correo
                                    </small>

                                    <span class="badge bg-light text-dark border mt-1">
                                        @pedido.TipoCliente
                                    </span>
                                </td>

                                <td>
                                    <div class="fw-semibold text-dark">
                                        @pedido.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy")
                                    </div>

                                    <small class="text-muted">
                                        @pedido.FechaPedido.ToLocalTime().ToString("HH:mm")
                                    </small>
                                </td>

                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                                        @cantidadProductos producto(s)
                                    </span>
                                </td>

                                <td>
                                    @if (pedido.EstadoPago == "Autorizado")
                                    {
                                        <span class="badge bg-success px-3 py-2">
                                            <i class="fa-solid fa-circle-check me-1"></i> Autorizado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2">
                                            <i class="fa-solid fa-clock me-1"></i> @pedido.EstadoPago
                                        </span>
                                    }
                                </td>

                                <td style="min-width: 170px;">
                                    @if (esDemoAdmin)
                                    {
                                        @switch (pedido.EstadoPedido)
                                        {
                                            case "Pagado":
                                                <span class="badge bg-primary px-3 py-2">Pagado</span>
                                                break;

                                            case "Preparando":
                                                <span class="badge bg-info text-dark px-3 py-2">Preparando</span>
                                                break;

                                            case "Enviado":
                                                <span class="badge bg-warning text-dark px-3 py-2">Enviado</span>
                                                break;

                                            case "Entregado":
                                                <span class="badge bg-success px-3 py-2">Entregado</span>
                                                break;

                                            case "Cancelado":
                                                <span class="badge bg-danger px-3 py-2">Cancelado</span>
                                                break;

                                            default:
                                                <span class="badge bg-secondary px-3 py-2">@pedido.EstadoPedido</span>
                                                break;
                                        }

                                        <div class="small text-muted mt-1">
                                            <i class="fa-solid fa-lock me-1"></i> Solo lectura
                                        </div>
                                    }
                                    else
                                    {
                                        <form asp-controller="Pedidos"
                                              asp-action="CambiarEstado"
                                              method="post"
                                              class="d-flex gap-2 align-items-center">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="id" value="@pedido.Id" />

                                            <select name="estadoPedido" class="form-select form-select-sm rounded-3">
                                                <option value="Pagado" selected="@(pedido.EstadoPedido == "Pagado")">Pagado</option>
                                                <option value="Preparando" selected="@(pedido.EstadoPedido == "Preparando")">Preparando</option>
                                                <option value="Enviado" selected="@(pedido.EstadoPedido == "Enviado")">Enviado</option>
                                                <option value="Entregado" selected="@(pedido.EstadoPedido == "Entregado")">Entregado</option>
                                                <option value="Cancelado" selected="@(pedido.EstadoPedido == "Cancelado")">Cancelado</option>
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-dark rounded-3 fw-bold">
                                                <i class="fa-solid fa-floppy-disk"></i>
                                            </button>
                                        </form>
                                    }
                                </td>

                                <td class="text-end">
                                    <span class="fw-black text-dark">
                                        $ @pedido.Total.ToString("N0")
                                    </span>
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-controller="Pedidos"
                                       asp-action="Detalle"
                                       asp-route-id="@pedido.Id"
                                       class="btn btn-sm btn-outline-primary fw-bold rounded-3">
                                        <i class="fa-solid fa-eye me-1"></i> Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>