@{
    ViewData["Title"] = "Transacción Fallida";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <i class="fa-solid fa-circle-xmark text-danger display-1 mb-4"></i>
            <h2 class="fw-black text-dark mb-2">Pago Rechazado o Cancelado</h2>
            <p class="text-muted mb-4">La pasarela de Webpay no pudo autorizar la transacción. Esto puede deberse a fondos insuficientes, datos de tarjeta erróneos o cancelación manual del flujo.</p>

            <div class="card p-3 border rounded-4 bg-white shadow-sm mb-4">
                <small class="text-muted fw-bold"><i class="fa-solid fa-circle-info text-warning me-1"></i> Entorno Sandbox / Pruebas</small>
                <span class="small text-muted mt-1">Recuerda usar las tarjetas de prueba autorizadas por Transbank para simular flujos exitosos.</span>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-bold px-4 rounded-3">
                    <i class="fa-solid fa-house me-1"></i> Ir al Inicio
                </a>
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary fw-bold px-4 rounded-3 shadow">
                    Reintentar Pago <i class="fa-solid fa-rotate-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>