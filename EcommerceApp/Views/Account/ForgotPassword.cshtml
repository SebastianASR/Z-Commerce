@model EcommerceApp.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border rounded-4 bg-dark text-white p-4" style="border-color: #334155 !important;">
                <div class="card-body text-start">
                    <div class="text-center mb-4">
                        <h3 class="fw-black text-primary mb-1">
                            <i class="fa-solid fa-key me-2"></i>Recuperar acceso
                        </h3>

                        <p class="text-muted small">
                            Ingresa tu correo y te enviaremos un enlace seguro para cambiar tu contraseña.
                        </p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label small fw-bold text-secondary">
                                CORREO ELECTRÓNICO
                            </label>

                            <input asp-for="Email"
                                   type="email"
                                   class="form-control bg-transparent text-white border-secondary rounded-3 py-2"
                                   placeholder="ejemplo@zcommerce.cl" />

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2 rounded-3 shadow-sm mb-3">
                            Enviar enlace de recuperación
                            <i class="fa-solid fa-paper-plane ms-1"></i>
                        </button>
                    </form>

                    <div class="text-center pt-2 border-top border-secondary mt-3">
                        <p class="mb-0 small text-muted">
                            ¿Recordaste tu contraseña?
                            <a asp-action="Login"
                               class="text-primary text-decoration-none fw-bold">
                                Volver al login
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}